{
  "$id": "graphql-operations.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "graphql-operations@1",
  "description": "Collection of GraphQL operations against an upstream [graphql](graphql.json) or [supergraph](supergraph.json) source. See [components](../components.md#graphql-operations).",
  "allOf": [{ "$ref": "common.json#/$defs/baseComponent" }],
  "properties": {
    "name": true,
    "title": true,
    "version": true,
    "description": true,
    "owner": true,
    "source": true,
    "manifest": true,
    "workspacePath": true,
    "type": {
      "const": "graphql-operations@1"
    },
    "config": {
      "type": "object",
      "properties": {
        "codeMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable code mode for dynamic operation execution"
        }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "object",
      "description": "Must reference exactly one graphql@1 or supergraph@1 source.",
      "additionalProperties": { "$ref": "common.json#/$defs/dependency" }
    },
    "sourceFiles": {
      "$ref": "common.json#/$defs/sourceFiles",
      "description": ".graphql files containing OperationDefinition entries"
    },
    "buildMeta": {
      "type": "object",
      "properties": {
        "operationDescriptors": {
          "type": "array",
          "description": "Pre-built operation metadata"
        },
        "schemaSdl": {
          "type": "string",
          "description": "Upstream schema SDL"
        }
      }
    }
  },
  "required": ["name", "type", "dependencies"],
  "additionalProperties": false
}
