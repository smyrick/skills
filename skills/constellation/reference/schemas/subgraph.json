{
  "$id": "subgraph.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "subgraph@1",
  "description": "Apollo Federation subgraph endpoint. Used as building blocks for [supergraph](supergraph.json). See [components](../components.md#subgraph).",
  "allOf": [{ "$ref": "common.json#/$defs/baseComponent" }],
  "properties": {
    "name": true,
    "title": true,
    "version": true,
    "description": true,
    "owner": true,
    "source": true,
    "manifest": true,
    "workspacePath": true,
    "type": {
      "const": "subgraph@1"
    },
    "config": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "description": "Subgraph GraphQL endpoint. Supports ${VAR} expansion."
        },
        "headers": {
          "type": "object",
          "description": "Custom headers. Supports ${VAR} expansion.",
          "additionalProperties": { "type": "string" }
        }
      },
      "required": ["url"],
      "additionalProperties": false
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": { "$ref": "common.json#/$defs/dependency" }
    }
  },
  "required": ["name", "type", "config"],
  "additionalProperties": false
}
