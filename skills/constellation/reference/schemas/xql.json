{
  "$id": "xql.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "xql@1",
  "description": "XQL query executor for multi-source data orchestration. See [xql reference](../xql.md) and [components](../components.md#xql).",
  "allOf": [{ "$ref": "common.json#/$defs/baseComponent" }],
  "properties": {
    "name": true,
    "title": true,
    "version": true,
    "description": true,
    "owner": true,
    "source": true,
    "manifest": true,
    "workspacePath": true,
    "type": {
      "const": "xql@1"
    },
    "config": {
      "type": "object",
      "additionalProperties": true
    },
    "dependencies": {
      "type": "object",
      "description": "References to data sources (graphql@1, rest@1, etc.). Namespace sets the reference name in XQL.",
      "additionalProperties": { "$ref": "common.json#/$defs/dependency" },
      "minProperties": 1
    },
    "sourceFiles": {
      "$ref": "common.json#/$defs/sourceFiles",
      "description": ".xql files containing operation definitions. Operations annotated with @tool become exposed tools."
    },
    "buildMeta": {
      "type": "object",
      "properties": {
        "schemaProvider": {
          "description": "Compiled schema information"
        },
        "toolDescriptors": {
          "type": "array",
          "description": "Descriptors for @tool-annotated operations"
        }
      }
    }
  },
  "required": ["name", "type", "dependencies", "sourceFiles"],
  "additionalProperties": false
}
