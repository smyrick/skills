{
  "$id": "supergraph.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "supergraph@1",
  "description": "Apollo Federation gateway composing [subgraphs](subgraph.json). See [components](../components.md#supergraph).",
  "allOf": [{ "$ref": "common.json#/$defs/baseComponent" }],
  "properties": {
    "name": true,
    "title": true,
    "version": true,
    "description": true,
    "owner": true,
    "source": true,
    "manifest": true,
    "workspacePath": true,
    "type": {
      "const": "supergraph@1"
    },
    "config": {
      "type": "object",
      "additionalProperties": true
    },
    "dependencies": {
      "type": "object",
      "description": "References to subgraph@1 components. Requires at least one.",
      "additionalProperties": { "$ref": "common.json#/$defs/dependency" },
      "minProperties": 1
    },
    "sourceFiles": { "$ref": "common.json#/$defs/sourceFiles" },
    "buildMeta": {
      "type": "object",
      "properties": {
        "supergraphSdl": {
          "type": "string",
          "description": "Pre-composed federation SDL"
        }
      }
    }
  },
  "required": ["name", "type", "dependencies"],
  "additionalProperties": false
}
