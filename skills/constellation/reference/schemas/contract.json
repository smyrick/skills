{
  "$id": "contract.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "contract@1",
  "description": "API contract/schema definition for schema governance and validation. Filters a [supergraph](supergraph.json) to limit exposure. See [components](../components.md#contract).",
  "allOf": [{ "$ref": "common.json#/$defs/baseComponent" }],
  "properties": {
    "name": true,
    "title": true,
    "version": true,
    "description": true,
    "owner": true,
    "source": true,
    "manifest": true,
    "workspacePath": true,
    "type": {
      "const": "contract@1"
    },
    "config": {
      "type": "object",
      "additionalProperties": true
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": { "$ref": "common.json#/$defs/dependency" }
    },
    "sourceFiles": {
      "$ref": "common.json#/$defs/sourceFiles",
      "description": "Contract definition files (e.g. contract.yaml)"
    }
  },
  "required": ["name", "type"],
  "additionalProperties": false
}
